# =============================================================
# Procurely Environment Variables
# Copy this file to backend/.env and fill in real values
# NEVER commit your actual .env file
# =============================================================

# Application Environment: development | staging | production
APP_ENV=development

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/procurely
# For SQLite fallback (local dev without Docker):
# DATABASE_URL=sqlite:///./procurely.db

# Redis (for rate limiting and caching)
REDIS_URL=redis://localhost:6379

# Security — CHANGE THESE IN PRODUCTION
APP_MASTER_KEY=generate-a-random-32-byte-hex-key
JWT_SECRET_KEY=generate-a-random-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Default admin credentials (override for production)
DEFAULT_ADMIN_EMAIL=admin@procurely.dev
DEFAULT_ADMIN_PASSWORD=change-this-to-a-strong-password

# CORS — comma-separated origins for production
BACKEND_CORS_ORIGINS=["http://localhost:5173"]

# Frontend
VITE_API_URL=/api/v1
